# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# Application
APP_NAME="Deriv AI Trading Platform"
APP_ENV=development          # development | production
DEBUG=true
SECRET_KEY=change-me-to-a-long-random-string-at-least-64-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# Database  (PostgreSQL)
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/deriv_trading
SYNC_DATABASE_URL=postgresql://user:password@localhost:5432/deriv_trading

# Deriv API
DERIV_APP_ID=1234               # Get from https://api.deriv.com/
DERIV_WS_URL=wss://ws.derivws.com/websockets/v3
DERIV_API_TOKEN=                # User's own API token — stored per-user in DB

# CORS origins (comma-separated)
CORS_ORIGINS=http://localhost,http://localhost:3000,https://your-app.onrender.com

# Firebase (push notifications) — base64-encoded service-account JSON
FIREBASE_CREDENTIALS_BASE64=

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
